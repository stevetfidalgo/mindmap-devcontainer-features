{
    "id": "bao-env",
    "version": "1.1.0",
    "name": "bao-env",
    "description": "OpenBao environment variable manager — CLI for viewing, checking, comparing, syncing, and managing config/secrets in OpenBao KV stores from a YAML manifest.",
    "documentationURL": "https://github.com/stevetfidalgo/mindmap-devcontainer-features/tree/main/src/bao-env",
    "options": {
        "baoVersion": {
            "type": "string",
            "default": "2.1.1",
            "description": "OpenBao CLI version to install"
        },
        "yqVersion": {
            "type": "string",
            "default": "4.52.4",
            "description": "yq (YAML processor) version to install"
        }
    },
    "containerEnv": {},
    "installsAfter": []
}
